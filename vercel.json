{
  "version": 2,
  "installCommand": "npm ci && cd frontend && npm ci",
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/api/cron-email",
      "destination": "/api/cron-email.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
