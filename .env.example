# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Email Service Provider
# Options: 'resend', 'sendgrid', 'console'
# Use 'console' for testing (no real emails sent)
EMAIL_SERVICE=console

# Sender Email
FROM_EMAIL=noreply@eswatinitransport.com

# Resend Configuration (if using Resend)
# Sign up at https://resend.com for free tier (100 emails/day)
RESEND_API_KEY=re_your_api_key_here

# SendGrid Configuration (if using SendGrid)
# Sign up at https://sendgrid.com for free tier (100 emails/day)
# SENDGRID_API_KEY=SG.your_api_key_here
